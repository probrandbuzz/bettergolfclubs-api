{%- comment -%}Better Golf Clubs Trade-In Calculator - Final{%- endcomment -%}

<style>
  .tradein-wrap{width:100%;margin:0;padding:0;display:block;}
  #tradein-iframe{width:1px;min-width:100%;border:none;display:block;height:1100px;}
  .shopify-section,.shopify-section>div{padding:0!important;margin:0!important;}
</style>

<div class="tradein-wrap">
  <iframe id="tradein-iframe" scrolling="no" frameborder="0"></iframe>
</div>

<script>
(function(){
  var el=document.getElementById('tradein-iframe');
  var d=el.contentDocument||el.contentWindow.document;
  d.open('text/html','replace');
  d.write(atob(""));
  d.close();
  window.addEventListener('message',function(e){
    if(e.data&&e.data.type==='tradein-height'&&e.data.height>200)
      el.style.height=e.data.height+'px';
  });
  function resize(){try{var dd=el.contentDocument||el.contentWindow.document;var h=Math.max(dd.body.scrollHeight,dd.documentElement.scrollHeight);if(h>200)el.style.height=h+'px';}catch(e){}}
  [300,700,1200,2000,3500].forEach(function(t){setTimeout(resize,t);});
  setInterval(resize,800);
})();
</script>

