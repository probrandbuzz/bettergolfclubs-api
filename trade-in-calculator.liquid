{%- comment -%}Better Golf Clubs Trade-In Calculator - Final{%- endcomment -%}

<style>
  .tradein-wrap{width:100%;margin:0;padding:0;display:block;}
  #tradein-iframe{width:1px;min-width:100%;border:none;display:block;height:1100px;}
  .shopify-section,.shopify-section>div{padding:0!important;margin:0!important;}
</style>

<div class="tradein-wrap">
  <iframe id="tradein-iframe" scrolling="no" frameborder="0"></iframe>
</div>

<script>
(function(){
  var API_BASE = 'https://bettergolfclubs-api.vercel.app';
  var el = document.getElementById('tradein-iframe');
  var d  = el.contentDocument || el.contentWindow.document;

  // Write the calculator HTML into the iframe immediately
  d.open('text/html','replace');
  d.write(atob(""));
  d.close();

  // iframe resize
  window.addEventListener('message',function(e){
    if(e.data&&e.data.type==='tradein-height'&&e.data.height>200)
      el.style.height=e.data.height+'px';
  });
  function resize(){try{var dd=el.contentDocument||el.contentWindow.document;var h=Math.max(dd.body.scrollHeight,dd.documentElement.scrollHeight);if(h>200)el.style.height=h+'px';}catch(ex){}}
  [300,700,1200,2000,3500].forEach(function(t){setTimeout(resize,t);});
  setInterval(resize,800);

  // Fetch live pricing from the API (runs in Shopify page context -- no CORS issues)
  // Then deliver it to the iframe via postMessage
  function sendPricing(pricing){
    try{
      (el.contentWindow||el.contentDocument.defaultView).postMessage(
        {type:'tradein-pricing', pricing: pricing}, '*'
      );
    }catch(ex){ console.error('[tradein] postMessage failed',ex); }
  }

  fetch(API_BASE + '/api/tradein/pricing', {
    cache: 'no-store',
    headers: {'Cache-Control': 'no-cache'}
  })
  .then(function(r){
    if(!r.ok) throw new Error('HTTP '+r.status);
    return r.json();
  })
  .then(function(data){
    // Retry postMessage until the iframe is ready to receive it
    var attempts = 0;
    function tryPost(){
      attempts++;
      try{
        (el.contentWindow||el.contentDocument.defaultView).postMessage(
          {type:'tradein-pricing', pricing: data}, '*'
        );
      }catch(ex){
        if(attempts < 20) setTimeout(tryPost, 200);
      }
    }
    // Wait briefly for iframe document to be ready, then post
    setTimeout(tryPost, 150);
  })
  .catch(function(err){
    console.error('[tradein] pricing fetch failed:', err);
    setTimeout(function(){
      try{
        (el.contentWindow||el.contentDocument.defaultView).postMessage(
          {type:'tradein-pricing', error: true}, '*'
        );
      }catch(ex){}
    }, 150);
  });

})();
</script>

{%- schema -%}
{"name":"Trade-In Calculator","tag":"section","class":"section-trade-in","settings":[],"presets":[{"name":"Trade-In Calculator"}]}
{%- endschema -%}
