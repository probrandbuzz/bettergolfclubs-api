# ─── SUPABASE ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── EMAIL ───────────────────────────────────────────────────
# Who sends the emails
EMAIL_FROM=tradein@bettergolfclubs.shop
# Who receives new submission alerts
ADMIN_ALERT_EMAIL=admin@bettergolfclubs.shop

# SMTP credentials (works with any provider — see notes below)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tradein@bettergolfclubs.shop
SMTP_PASS=your-app-password-here

# ─── URLS ─────────────────────────────────────────────────────
# Your Shopify store (used in approval email "Shop now" links)
STORE_URL=https://bettergolfclubs.shop
# Your deployed admin panel (used in admin alert "Review" button)
ADMIN_PANEL_URL=https://admin.bettergolfclubs.shop
# Only allow requests from these origins (leave * for now, lock down after go-live)
ALLOWED_ORIGIN=*

# ─── SHOPIFY ─────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=bettergolfclubs.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── AUTH ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-generated-secret
NEXTAUTH_URL=https://your-api.vercel.app
